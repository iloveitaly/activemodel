There should be a better way to add unique keys

```
    __table_args__ = (
        # users should never see two schemas with the same name
        UniqueConstraint("note_type", "doctor_id", name="doctor_and_note_type_unique"),
    )
```

we should have the ability to do this:

```
def test_create_checkout_session_rejects_when_booked_in_past(client, db_session):
    screening = ScreeningFactory.save()
    screening.booked_datetime = SystemDateTime.now().add(days=-1).py_datetime()
    screening.save()

    response = client.post(
        api_app.url_path_for("create_checkout_session"),
        json={
            "screening_id": str(screening.id),
            "ticket_count": 1,
        },
        headers={"host": screening.distribution.domain},
    )

    assert_status(response, status.HTTP_400_BAD_REQUEST)
```